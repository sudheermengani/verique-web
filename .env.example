# Copy to .env and fill in. Next.js loads .env automatically in all envs.
# On Vercel, set these in Project → Settings → Environment Variables instead.

# Supabase transaction pooler (port 6543), NO +psycopg (this is the JS driver).
DATABASE_URL=postgresql://postgres.xxx:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres

# Admin auth (you + partner).
OPS_SESSION_SECRET=generate-with-openssl-rand-hex-32
OPS_EMAILS=you@verique.co.uk,partner@verique.co.uk
OPS_PASSWORD=change-me

# Client magic-link emails (Resend).
RESEND_API_KEY=re_xxx
LOGIN_FROM_EMAIL=Verique <contact@verique.co.uk>

# Optional. Absolute base URL used in magic-link emails. Leave unset and it
# uses the incoming request host (correct on Vercel automatically). Set it
# explicitly if you want to force the domain, e.g. behind a proxy.
# NEXT_PUBLIC_APP_URL=https://verique.co.uk

# "Run scan now" on the admin dashboard — dispatches the engine's GitHub
# Actions workflow (verique-engine's daily.yml) on demand, same as clicking
# "Run workflow" in the Actions tab by hand.
# Create at github.com/settings/tokens: fine-grained token scoped ONLY to the
# verique-engine repo, with "Actions: Read and write" permission. Never a
# broad classic token — this key lives on the web server, not just your laptop.
GITHUB_TOKEN=github_pat_xxx
# Defaults already match the real repo; only override if you fork/rename it.
# GITHUB_REPO=Nithin-Varma/verique-engine
# GITHUB_WORKFLOW_FILE=daily.yml
# GITHUB_REF_NAME=main
